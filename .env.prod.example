# Django Settings
DJANGO_SETTINGS_MODULE=config.settings.production
DEBUG=False
SECRET_KEY=your-super-secret-key-change-in-production

# Allowed Hosts (comma-separated — includes EC2 elastic IP)
ALLOWED_HOSTS=localhost,127.0.0.1,52.201.178.136

# Database — for EC2, use RDS or keep docker-compose postgres
DATABASE_URL=postgres://postgres:postgres@db:5432/django_boiler

# Redis (for Celery)
REDIS_URL=redis://redis:6379/0

# HTTPS — set to True if you put Cloudflare / ELB in front
USE_HTTPS=False

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_email@example.com
EMAIL_HOST_PASSWORD=your_app_password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@example.com

# JWT
JWT_SECRET_KEY=your-jwt-super-secret-key-change-in-production

# OTP
OTP_EXPIRATION_MINUTES=10
MAX_OTP_ATTEMPTS=5
