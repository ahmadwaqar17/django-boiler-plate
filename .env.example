# Django Settings
DJANGO_SETTINGS_MODULE=config.settings.dev
DEBUG=True
SECRET_KEY=your-super-secret-key-change-in-production

# Allowed Hosts (comma-separated — add EC2 elastic IP for production)
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,52.201.178.136

# Supabase Database Configuration
# Format: postgresql://user:password@host:port/database
# Get connection string from Supabase dashboard: Settings > Database > Connection pool
# Example: postgresql://postgres:your_password@db.your-project-ref.supabase.co:5432/postgres
DATABASE_URL=postgres://postgres:postgres@db:5432/django_boiler

# HTTPS toggle (set True behind TLS-terminating proxy)
USE_HTTPS=False

# Redis Configuration (for Celery)
REDIS_URL=redis://redis:6379/0

# Nginx
NGINX_SERVER_NAME=localhost 127.0.0.1
NGINX_DOMAIN=localhost

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_email@example.com
EMAIL_HOST_PASSWORD=your_app_password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@example.com

# JWT Configuration
JWT_SECRET_KEY=your-jwt-super-secret-key-change-in-production

# OTP Configuration (in minutes)
OTP_EXPIRATION_MINUTES=10
MAX_OTP_ATTEMPTS=5
